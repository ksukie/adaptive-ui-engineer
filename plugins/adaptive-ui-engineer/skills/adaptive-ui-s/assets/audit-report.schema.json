{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ksukie/adaptive-ui-engineer/v1.0.3/plugins/adaptive-ui-engineer/skills/adaptive-ui-s/assets/audit-report.schema.json",
  "title": "Adaptive UI Engineer audit report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool",
    "target",
    "config",
    "summary",
    "findings",
    "skipped_files"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "adaptive-ui-engineer" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      }
    },
    "target": { "type": "string", "minLength": 1 },
    "config": { "type": ["string", "null"] },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files_scanned", "files_skipped", "findings", "suppressed", "by_priority"],
      "properties": {
        "files_scanned": { "type": "integer", "minimum": 0 },
        "files_skipped": { "type": "integer", "minimum": 0 },
        "findings": { "type": "integer", "minimum": 0 },
        "suppressed": { "type": "integer", "minimum": 0 },
        "by_priority": {
          "type": "object",
          "additionalProperties": false,
          "required": ["P0", "P1", "P2", "P3"],
          "properties": {
            "P0": { "type": "integer", "minimum": 0 },
            "P1": { "type": "integer", "minimum": 0 },
            "P2": { "type": "integer", "minimum": 0 },
            "P3": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "skipped_files": {
      "type": "array",
      "items": { "$ref": "#/$defs/skippedFile" }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "validation_state": { "enum": ["reproduced", "not_reproduced"] }
            },
            "required": ["validation_state"]
          },
          "then": {
            "properties": {
              "evidence_level": { "const": "runtime_observed" }
            }
          }
        }
      ],
      "required": [
        "rule_id",
        "priority",
        "confidence",
        "evidence_level",
        "validation_state",
        "category",
        "path",
        "line",
        "message",
        "evidence",
        "recommendation"
      ],
      "properties": {
        "rule_id": { "type": "string", "pattern": "^AUI[0-9]{3}$" },
        "priority": { "enum": ["P0", "P1", "P2", "P3"] },
        "confidence": { "enum": ["high", "medium", "low"] },
        "evidence_level": {
          "enum": ["source_observed", "static_inferred", "runtime_observed"]
        },
        "validation_state": {
          "enum": [
            "not_applicable",
            "not_run",
            "reproduced",
            "not_reproduced",
            "manual_review_needed"
          ]
        },
        "category": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "message": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string" },
        "recommendation": { "type": "string", "minLength": 1 }
      }
    },
    "skippedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "reason"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
