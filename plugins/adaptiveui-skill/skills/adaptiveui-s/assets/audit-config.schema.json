{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/ksukie/AdaptiveUI-SKILL/v2.0.0/plugins/adaptiveui-skill/skills/adaptiveui-s/assets/audit-config.schema.json",
  "title": "AdaptiveUI-SKILL audit configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "exclude": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "ignore": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule", "paths", "reason"],
        "properties": {
          "rule": { "type": "string", "pattern": "^AUI[0-9]{3}$" },
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "reason": { "type": "string", "minLength": 4 }
        }
      }
    },
    "fail_on": {
      "enum": ["P0", "P1", "P2", "P3", "none"]
    }
  }
}
